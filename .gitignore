########################
# GameMaker Studio 2
########################
# KEEP: *.yyp (project) and *.yy (resources) — commit these!
# Ignore build/cache/exports:
*.yyz           # exported project archives
*.yymps         # exported packages
*.temp          # temp files
*.tmp
*.log
cache/
output/
build/
# Some users see per-target caches:
# .gms/ or .gmx/ (legacy) — ignore if they appear
.gmx/
.gmlive/        # if using GMLive
local_settings.yy
# OS-specific caches inside project
*/.sync_cache/

